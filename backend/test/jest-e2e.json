{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "transformIgnorePatterns": ["/node_modules/", "/dist/"],
  "moduleNameMapper": {
    "^@crm/contracts$": "<rootDir>/../../packages/contracts/dist/index.js"
  }
}
