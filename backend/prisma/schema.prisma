// CRM module — Prisma schema.
// Author: Mohamed Marwen Maalawi — © 2026.
// Modeling rationale lives in DECISIONS.md (§1 client model, §2 stages/status, §3 problem rule).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientType {
  COMPANY
  INDIVIDUAL
}

enum OpportunityStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

/// Type of logged interaction on an opportunity (the CRM activity timeline).
enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
}

/// A client is either a COMPANY or an INDIVIDUAL.
/// Single-table discriminator: type-specific columns are nullable at the column level,
/// but a CHECK constraint (added in migration `add_client_type_check`) guarantees the
/// right fields are present for each `type`. See DECISIONS.md §1.
model Client {
  id        String     @id @default(uuid()) @db.Uuid
  type      ClientType
  // Common
  email     String?    @db.VarChar(180)
  phone     String?    @db.VarChar(40)
  ownerName String     @db.VarChar(120)
  // COMPANY-only
  legalName    String? @db.VarChar(180)
  siren        String? @db.VarChar(9)
  industry     String? @db.VarChar(120)
  headcount    String? @db.VarChar(16)
  // Primary contact (COMPANY-only) — a B2B CRM talks to a person, not a building.
  contactName  String? @db.VarChar(120)
  contactRole  String? @db.VarChar(120)
  contactEmail String? @db.VarChar(180)
  // INDIVIDUAL-only
  firstName String?    @db.VarChar(80)
  lastName  String?    @db.VarChar(80)

  opportunities Opportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("clients")
}

model Opportunity {
  id                String            @id @default(uuid()) @db.Uuid
  title             String            @db.VarChar(160)
  amount            Decimal           @db.Decimal(14, 2)
  expectedCloseDate DateTime          @db.Date
  stage             OpportunityStage  @default(NEW)
  status            OpportunityStatus @default(OPEN)
  ownerName         String            @db.VarChar(120)
  notes             String?           @db.VarChar(2000)

  /// Next concrete action and its due date — the sales rep's "what's next".
  nextStep      String?   @db.VarChar(200)
  nextStepDueAt DateTime? @db.Date

  /// Timestamp of the last `stage` change — fallback for the "stalled" rule.
  stageChangedAt DateTime @default(now())
  /// Timestamp of the most recent logged activity — primary signal for "stalled"
  /// (DECISIONS.md §3). Denormalized from `activities` so list/aggregation stay cheap.
  lastActivityAt DateTime?

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  clientId   String      @db.Uuid
  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([stage])
  @@index([expectedCloseDate])
  @@index([clientId])
  @@index([nextStepDueAt])
  @@map("opportunities")
}

/// A logged interaction on an opportunity (call, email, meeting, note).
/// This timeline is what turns a record store into a CRM.
model Activity {
  id            String       @id @default(uuid()) @db.Uuid
  type          ActivityType
  summary       String       @db.VarChar(1000)
  occurredAt    DateTime
  authorName    String       @db.VarChar(120)
  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId String       @db.Uuid
  createdAt     DateTime     @default(now())

  @@index([opportunityId, occurredAt])
  @@map("activities")
}
